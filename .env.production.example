# ──────────────────────────────────────────────────────────────
# HireMind Production Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in ALL values:
#   cp .env.production.example .env.production
#
# ⚠️  SECURITY NOTES:
#   - NEVER commit .env.production to version control
#   - Use strong, random passwords (≥ 32 chars) for all secrets
#   - JWT_SECRET_KEY must be unique per environment
#   - Rotate secrets periodically
#
# Generate random secrets:
#   openssl rand -hex 32
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=hiremind
POSTGRES_USER=hiremind
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD_32CHARS_MIN>

# ── Redis ─────────────────────────────────────────────────────
# No password by default (Redis is on internal network only).
# To enable Redis AUTH, set REDIS_PASSWORD and update REDIS_URL.
# REDIS_PASSWORD=<CHANGE_ME>

# ── MinIO (S3-compatible object storage) ──────────────────────
MINIO_ROOT_USER=<CHANGE_ME_MINIO_ACCESS_KEY>
MINIO_ROOT_PASSWORD=<CHANGE_ME_MINIO_SECRET_KEY_32CHARS_MIN>

# ── FastAPI Backend ──────────────────────────────────────────
# Full async PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://hiremind:<POSTGRES_PASSWORD>@postgres:5432/hiremind

# Individual Postgres connection params (used by some helpers)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<SAME_AS_MINIO_ROOT_USER>
MINIO_SECRET_KEY=<SAME_AS_MINIO_ROOT_PASSWORD>
MINIO_BUCKET_RESUMES=resumes
MINIO_SECURE=false

# ── Authentication ───────────────────────────────────────────
# ⚠️  CRITICAL: JWT_SECRET_KEY has NO default in production.
#     The application will refuse to start without this value.
#     Generate with: openssl rand -hex 32
JWT_SECRET_KEY=<CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32>

# ── Application ──────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:8081","https://hiremind.example.com"]
