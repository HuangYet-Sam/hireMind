# ===========================================
# HireMind FastAPI Backend 环境变量配置
# ===========================================

# 应用
APP_NAME=HireMind
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://hiremind:hiremind@localhost:5432/hiremind

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (文件存储)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hiremind
MINIO_SECURE=false

# JWT认证
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Hermes Agent
HERMES_AGENT_URL=http://localhost:8642

# LLM (用于AI推理)
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o

# CORS
CORS_ORIGINS=http://localhost:8648,http://localhost:5173

# 日志
LOG_LEVEL=INFO
