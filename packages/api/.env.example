# ═══════════════════════════════════════════════════════════════
# HireMind Backend Configuration
# Copy this file to .env and customize values before running.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
APP_NAME=HireMind
APP_VERSION=0.1.0
# Environment: "development" or "production"
# When set to "production", additional security checks are enforced:
#   - POSTGRES_PASSWORD must not be the dev default
#   - MinIO credentials (MINIO_ACCESS_KEY / MINIO_SECRET_KEY) must not be defaults
#   - DEBUG must be false
#   - MINIO_SECURE must be true (use TLS)
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hiremind
# ⚠️  [MUST CHANGE] Set a strong password for production
POSTGRES_PASSWORD=hiremind_dev
POSTGRES_DB=hiremind
DATABASE_URL=postgresql+asyncpg://hiremind:hiremind_dev@localhost:5432/hiremind
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO / S3 ───────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
# ⚠️  [MUST CHANGE] Set custom access/secret keys for production
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RESUMES=resumes
# Set to true in production to use TLS
MINIO_SECURE=false

# ── JWT Authentication ───────────────────────────────────
# ⚠️  [REQUIRED] MUST be set to a strong random string.
#    The application will refuse to start if this is empty or
#    still set to "change-me-in-production".
#    Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Hermes Agent Integration ─────────────────────────────
HERMES_AGENT_URL=http://localhost:8648
HERMES_AGENT_API_KEY=
HERMES_AGENT_MODEL=default

# ── OpenAI / LLM ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_RESUME=gpt-4o-mini
OPENAI_MODEL_MATCHING=gpt-4o-mini

# ── File Upload ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# ── Pagination ───────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8648","http://localhost:3000","http://localhost:5173"]
