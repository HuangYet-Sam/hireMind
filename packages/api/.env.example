# ── Application ──────────────────────────────────────────
APP_NAME=HireMind
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hiremind:hiremind_dev@localhost:5432/hiremind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hiremind
POSTGRES_PASSWORD=hiremind_dev
POSTGRES_DB=hiremind
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO / S3 ───────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RESUMES=resumes
MINIO_SECURE=false

# ── JWT Authentication ───────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Hermes Agent Integration ─────────────────────────────
HERMES_AGENT_URL=http://localhost:8648
HERMES_AGENT_API_KEY=

# ── OpenAI / LLM ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_RESUME=gpt-4o-mini

# ── File Upload ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8648","http://localhost:3000","http://localhost:5173"]
